DATABASE_URL="mysql://user:password@host:3306/database"

JWT_SECRET_GATEWAY=replace-with-a-gateway-only-admin-secret
# Protects only the gateway's own /jwt-secrets/external/active endpoint.
# Unrelated to INTERNAL_KEY used between cart/orders/catalog — different name, different value.
INTERNAL_API_KEY=replace-with-an-internal-api-key
