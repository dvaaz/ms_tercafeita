PORT=3040
DATABASE_URL="mysql://user:password@host:3306/database"
ALLOWED_ORIGINS=http://localhost:5173
INTERNAL_KEY=replace-with-the-shared-internal-key
# Access token (15min) é assinado com a secret ativa buscada do gateway, não com uma secret fixa.
# Use http://gateway:3000 quando rodando via docker-compose (overridden there already).
GATEWAY_URL=http://localhost:3000
INTERNAL_API_KEY=replace-with-the-gateway-internal-api-key
JWT_EXPIRES_IN=15m
# Secret fixa e separada, só pro refresh token (7 dias) — não rotaciona.
JWT_REFRESH_SECRET=replace-with-a-refresh-only-secret
JWT_REFRESH_EXPIRES_IN=7d
