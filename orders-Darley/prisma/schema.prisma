generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model pedido {
  pedido_uuid              String              @id @db.Char(36)
  pedido_valor_total       Int
  usuario_uuid             String              @db.Char(36)
  endereco_de_entrega_uuid String              @db.Char(36)
  status_pedido_id         Int
  pedido_nome_destinatario String              @db.VarChar(150)
  pedido_created_at        DateTime            @default(now()) @db.Timestamp(0)
  pedido_updated_at        DateTime            @default(now()) @db.Timestamp(0)
  item_pedido              item_pedido[]
  pagamento                pagamento[]
  endereco_de_entrega      endereco_de_entrega @relation(fields: [endereco_de_entrega_uuid], references: [endereco_uuid], onUpdate: Restrict, map: "fk_pedido_endereco")
  status_pedido            status_pedido       @relation(fields: [status_pedido_id], references: [status_pedido_id], onUpdate: Restrict, map: "fk_pedido_status")

  @@index([endereco_de_entrega_uuid], map: "endereco_de_entrega_uuid")
  @@index([status_pedido_id], map: "status_pedido_id")
}

model item_pedido {
  item_pedido_id           Int      @id @default(autoincrement())
  pedido_uuid              String   @db.Char(36)
  id_produto               Int
  item_pedido_nome_produto String   @db.VarChar(150)
  item_pedido_preco        Int
  item_pedido_total_preco  Int
  item_pedido_quantidade   Int
  item_pedido_created_at   DateTime @default(now()) @db.Timestamp(0)
  item_pedido_updated_at   DateTime @default(now()) @db.Timestamp(0)
  pedido                   pedido   @relation(fields: [pedido_uuid], references: [pedido_uuid], onUpdate: Restrict, map: "fk_item_pedido")

  @@index([pedido_uuid], map: "pedido_uuid")
}

model endereco_de_entrega {
  endereco_uuid         String   @id @db.Char(36)
  endereco_uf           String   @db.VarChar(45)
  endereco_municipio    String   @db.VarChar(45)
  endereco_logradouro   String   @db.VarChar(45)
  endereco_numero       Int
  endereco_complemento  String?  @db.VarChar(45)
  endereco_cep          String   @db.VarChar(10)
  endereco_created_at   DateTime @default(now()) @db.Timestamp(0)
  endereco_updated_at   DateTime @default(now()) @db.Timestamp(0)
  endereco_usuario_uuid String?  @db.VarChar(36)
  pedido                pedido[]
}

model status_pedido {
  status_pedido_id   Int      @id @default(autoincrement())
  status_pedido_nome String?  @db.VarChar(50)
  pedido             pedido[]
}

model pagamento {
  pagamento_uuid                   String               @id @db.Char(36)
  pagamento_numero_parcelas        Int?
  pagamento_valor_primeira_parcela Int?
  pagamento_valor_parcelas         Int?
  metodos_de_pagamento_id          Int
  codigo_do_pagamento              String               @db.VarChar(100)
  pedido_uuid                      String               @db.Char(36)
  status_pagamento_id              Int
  pagamento_created_at             DateTime             @default(now()) @db.Timestamp(0)
  pagamento_updated_at             DateTime             @default(now()) @db.Timestamp(0)
  pedido                           pedido               @relation(fields: [pedido_uuid], references: [pedido_uuid], onUpdate: Restrict)
  metodo                           metodos_de_pagamento @relation(fields: [metodos_de_pagamento_id], references: [metodos_de_pagamento_id], onUpdate: Restrict)
  status                           status_pagamento     @relation(fields: [status_pagamento_id], references: [status_pagamento_id], onUpdate: Restrict)

  @@index([pedido_uuid])
  @@index([metodos_de_pagamento_id])
  @@index([status_pagamento_id])
}

model metodos_de_pagamento {
  metodos_de_pagamento_id  Int         @id @default(autoincrement())
  metodo_de_pagamento_nome String?     @db.VarChar(45)
  pagamento                pagamento[]
}

model status_pagamento {
  status_pagamento_id   Int         @id @default(autoincrement())
  status_pagamento_nome String      @db.VarChar(45)
  pagamento             pagamento[]
}
